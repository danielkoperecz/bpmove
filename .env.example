# ---- BPMOVE – Vercel function env ----
# Lokálisan: másold le ".env.local" néven és töltsd ki. A `vercel dev`
# automatikusan betölti. Élesben: állítsd be a Vercel dashboardon
# (Project Settings → Environment Variables).

# Ide fog menni minden árajánlatkérés
RECIPIENT_EMAIL=sevendiko@gmail.com

# Feladó, ahogy a beérkező levélben megjelenik
MAIL_FROM="BPMOVE árajánlat <no-reply@bpmove.hu>"

# ---- SMTP beállítások ----

# 1) Gmail példa (App Password szükséges: https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx

# 2) Resend példa (ajánlott tranzakcionális e-mailhez)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxx

# 3) SendGrid példa
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxxxxxxxxxx
